# Climb-Forge — 프론트 환경변수 예시
# 실제 사용 시 `.env.local`로 복사하여 채움 (.gitignore됨).

# PocketBase API URL. 로컬은 docker compose의 호스트 포트.
# 운영은 ADR-2/S13의 Caddy 도메인 (예: https://pb.climb-forge.example).
NEXT_PUBLIC_PB_URL=http://localhost:8090

# scripts/smoke.mjs 인증 흐름 검증용 (선택). PB admin UI에서 미리 만든 테스트 계정.
# 미설정 시 비인증 라우트만 검증.
# CF_TEST_EMAIL=test@example.com
# CF_TEST_PASSWORD=...
# CF_BASE_URL=http://localhost:3000
