# Breakteau Caddy — PB reverse proxy + 프론트 정적 서빙 (S13, S15).
#
# 자동 SSL (Let's Encrypt) + HTTP/2/3 + gzip + 보안 헤더.
# {$PB_DOMAIN} / {$APP_DOMAIN} / {$ACME_EMAIL}은 docker-compose가 환경변수로 주입.
{
	# 전역 옵션
	email {$ACME_EMAIL}
	# admin endpoint는 외부 노출 안 함.
	admin off
}

# ──────────────────────────────────────────────────────────────
# PocketBase API (백엔드)
# ──────────────────────────────────────────────────────────────
{$PB_DOMAIN} {
	# PocketBase로 reverse proxy. internal 네트워크의 서비스명으로 직접 호출.
	# X-Forwarded-For/Proto/Host는 Caddy 기본 전달.
	reverse_proxy pocketbase:8090

	# 보안 헤더 (모바일 PWA + admin UI 호환).
	header {
		# HSTS — 1년, 서브도메인 포함, preload 가능.
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# clickjacking 회피.
		X-Frame-Options "DENY"
		# MIME sniffing 회피.
		X-Content-Type-Options "nosniff"
		# Referrer 최소 노출.
		Referrer-Policy "strict-origin-when-cross-origin"
		# Caddy가 자동 추가하는 Server: 제거.
		-Server
	}

	# 압축 — JSON 응답 크기 절감.
	encode gzip zstd

	# 액세스 로그 — stdout(docker logs). 운영 grep/jq 위해 JSON.
	log {
		output stdout
		format json
		level INFO
	}
}

# ──────────────────────────────────────────────────────────────
# 프론트엔드 정적 서빙 (S15)
# ──────────────────────────────────────────────────────────────
# Next.js static export(`output: 'export'` + `trailingSlash: true`) 산출물을
# /srv/app에 마운트. file_server가 디스크에서 직접 서빙.
{$APP_DOMAIN} {
	root * /srv/app
	encode gzip zstd

	# Cache-Control:
	#   - /_next/static/* : 해시 기반 immutable 자산. 1년 cache.
	#   - /sw.js, /manifest.webmanifest, /icon.svg : 새 배포 즉시 반영해야 함
	#     (icon.svg는 PWA manifest 참조라 교체 시 즉시 적용 필요).
	#   - 그 외 HTML : 매번 재검증.
	@immutable path /_next/static/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	@no_cache path /sw.js /manifest.webmanifest /icon.svg
	header @no_cache Cache-Control "no-cache"

	@html path *.html /
	header @html Cache-Control "no-cache"

	# 보안 헤더 + PWA 호환.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Service Worker가 같은 origin에서 fetch만 → 보수적 CSP.
		# PB API 호출은 https://{$PB_DOMAIN}로 — connect-src에 추가.
		# 'unsafe-inline' (script-src/style-src) — Next.js RSC payload + 동적 style 때문에 불가피.
		#   hash 기반 CSP로 좁히려면 빌드 시점 hash 추출 필요 (v1.1 검토).
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://{$PB_DOMAIN}; manifest-src 'self'; worker-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# 파일 서빙 — try_files로 trailingSlash 라우트 매칭.
	# Next.js trailingSlash 모드는 `/foo/` → `/foo/index.html` 자동, 일반 파일은 그대로.
	try_files {path} {path}/ {path}.html
	file_server

	# 매칭 실패 → 404 status로 Next가 생성한 404.html 응답
	# (file_server가 200으로 fallback 서빙하지 않도록 handle_errors 사용).
	handle_errors {
		@notfound expression {http.error.status_code} == 404
		rewrite @notfound /404.html
		file_server
	}

	log {
		output stdout
		format json
		level INFO
	}
}
