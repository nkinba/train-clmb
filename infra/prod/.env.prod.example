# Breakteau 운영 환경변수 (S13).
# 실제 사용 시 `.env`로 복사 후 채움. `.env`는 .gitignore.

# Caddy가 자동 SSL 발급할 두 hostname (S13 PB + S15 프론트). ADR-2 기준 두 옵션:
#   - 커스텀 도메인:  pb.your-domain.com / app.your-domain.com
#   - 무료 DDNS:     <sub-pb>.duckdns.org / <sub-app>.duckdns.org
# 각 hostname의 A 레코드가 VM 외부 IP를 가리켜야 함. RUNBOOK §3 참조.
PB_DOMAIN=pb.breakteau.example.com
APP_DOMAIN=app.breakteau.example.com

# Let's Encrypt 만료 임박/실패 시 알림 이메일. PB_DOMAIN과 같은 도메인이 아니어도 무방.
ACME_EMAIL=admin@example.com

# 영속 데이터 디렉토리. Linux prod에서는 절대 경로 + 비-root user(uid 100)에 쓰기 권한 필수.
# RUNBOOK §4.0 참조 — `chown -R 100:101 <DATA_DIR>/pb_data` 단계가 첫 부팅 전에 필요.
DATA_DIR=/opt/breakteau/data

# ── 자동 백업 (S14, ADR-6 — GCS) ──────────────────────────────────────
# PB admin 자격증명 — backup 컨테이너가 PB admin API(`POST /api/backups`)를 호출.
# 1Password 등에서 안전하게 관리. 절대 git에 commit 금지.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=

# 백업 스케줄 (UTC). 기본 19:00 UTC = 04:00 KST.
# BACKUP_HOUR_UTC=19
# BACKUP_MINUTE_UTC=0

# 컨테이너 시작 직후 1회 실행 (검증용). 운영은 0 권장.
# BACKUP_ON_START=0

# GCP Cloud Storage (S3 호환 / Interoperability + HMAC). RUNBOOK §7.3에서 버킷/SA/HMAC 절차.
# 미디어(v1.1)는 별도 버킷(`breakteau-media`) + 별도 SA/HMAC 권장 (권한 분리).
GCS_BUCKET=breakteau-backups
GCS_REGION=us-west1
GCS_ACCESS_KEY_ID=
GCS_SECRET_ACCESS_KEY=
# 백업 객체 sub-prefix (기본 auto/) — 미디어 객체와 cleanup 영향 분리.
# GCS_PREFIX=auto

# 백업 실패 시 알림 webhook (선택). Slack/Discord/Telegram 등 incoming webhook URL.
# 미설정 시 docker logs로만 추적 (RUNBOOK §6.1 주 1회 grep 권장).
# BACKUP_ALERT_WEBHOOK=https://hooks.slack.com/services/...

# ── 세션 미디어 (S18-A, v1.1) ──────────────────────────────────────────
# PB Admin UI → Settings → Files → Use S3 storage에 직접 입력하므로
# 컨테이너는 이 변수를 *직접 읽지 않음*. 운영자가 1Password와 함께 .env에
# 보관해서 재배포/장애복구 시 admin UI 재설정 입력을 빠르게 하기 위한 메타데이터.
# 발급 절차 + UI 설정 절차는 RUNBOOK §7.5.
#
# 별도 버킷 `breakteau-media` (us-west1) + 별도 SA HMAC. 백업 SA와 권한 격리.
MEDIA_GCS_BUCKET=breakteau-media
MEDIA_GCS_REGION=us-west1
MEDIA_GCS_ACCESS_KEY_ID=
MEDIA_GCS_SECRET_ACCESS_KEY=
